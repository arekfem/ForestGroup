<body class="offers-page">
    <!-- @include 'nav.kit' -->
    <header class="section subpage-header">
        <h1 class="header__title">Oferta</h1>
    </header>
    <main>
        <section class="section-padding">
            <div class="wrapper">
                <h2 class="section-heading">Skorzystaj z <span>oferty!</span></h2>
                <div class="offer">
                    <div class="offer__box-big">
                        <img class="offer__img" src="./dist/img/avenue_640.jpg"
                            alt="leśna ścieżka w blasku promieni słonecznych">
                        <div class="offer__box">
                            <h3 class="offer__title">Demo</h3>
                            <p class="offer__price">0$</p>
                            <ul class="offers__list">
                                <li class="offers__list-item active-item">opcja w pakiecie</li>
                                <li class="offers__list-item active-item">opcja w pakiecie</li>
                            </ul>
                        </div>
                    </div>
                    <p class="offer__description">Lorem ipsum, dolor sit amet consectetur adipisicing elit. Qui
                        quisquam, dolorem esse consectetur nisi nobis eveniet eum. Consequatur quo deserunt doloribus
                        modi deleniti corporis doloremque officiis neque, vel, eveniet quibusdam. </p>
                    <p class="offer__description"> Sit mollitia beatae officiis sed exercitationem veniam
                        dignissimos porro repellendus, sapiente, expedita reprehenderit aliquam non repudiandae in
                        ipsam voluptatum nam tempore suscipit ad, dolores ex veritatis quisquam vitae nihil!
                        Debitis, itaque aliquam!</p>
                    <button class="offer__btn">Wybierz</button>
                </div>
                <div class="offer">
                    <div class="offer__box-big">
                        <img class="offer__img" src="./dist/img/flowers_640.jpg"
                            alt="motyl lecący w stronę kwiatów w pomarańczowych barwach">
                        <div class="offer__box">
                            <h3 class="offer__title">Standard</h3>
                            <p class="offer__price">99$</p>
                            <ul class="offers__list">
                                <li class="offers__list-item active-item">opcja w pakiecie</li>
                                <li class="offers__list-item active-item">opcja w pakiecie</li>
                                <li class="offers__list-item active-item">opcja w pakiecie</li>
                            </ul>
                        </div>
                    </div>
                    <p class="offer__description">Lorem ipsum dolor sit amet consectetur adipisicing elit. Est
                        debitis a aut quia laudantium odit sequi et nobis ut dignissimos. Nulla, asperiores? Aperiam
                        quod ipsa, eum a ex ullam itaque corporis accusantium voluptas reiciendis odit ratione quasi
                        quae dolor cumque minus veritatis soluta eius earum sit aspernatur voluptatibus! </p>
                    <p class="offer__description"> Sit mollitia beatae officiis sed exercitationem veniam
                        dignissimos porro repellendus, sapiente, expedita reprehenderit aliquam non repudiandae in
                        ipsam voluptatum nam tempore suscipit ad, dolores ex veritatis quisquam vitae nihil!
                        Debitis, itaque aliquam!</p>
                    <button class="offer__btn offer__btn--special">Wybierz</button>
                </div>
                <div class="offer">
                    <div class="offer__box-big">
                        <img class="offer__img" src="./dist/img/bridge_640.jpg" alt="wiszący most na linach w lesie">
                        <div class="offer__box">
                            <h3 class="offer__title">Premium</h3>
                            <p class="offer__price">299$</p>
                            <ul class="offers__list">
                                <li class="offers__list-item active-item">opcja w pakiecie</li>
                                <li class="offers__list-item active-item">opcja w pakiecie</li>
                                <li class="offers__list-item active-item">opcja w pakiecie</li>
                                <li class="offers__list-item active-item">opcja w pakiecie</li>
                                <li class="offers__list-item active-item">opcja w pakiecie</li>
                            </ul>
                        </div>
                    </div>
                    <p class="offer__description">Lorem ipsum dolor sit, amet consectetur adipisicing elit. Impedit,
                        veritatis, ad repellendus laboriosam sint et dicta ducimus eum eligendi adipisci dolor deserunt
