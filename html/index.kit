<!DOCTYPE html>
<html lang="pl">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="author" content="arek0074">
    <meta name="keywords" content="Park natury przyroda cisza spokój oaza">
    <meta name="description"
        content="Odkryj piękno w parku natury Forest Group: urocze szlaki, dzika przyroda i cisza, która ukoi duszę. Oaza spokoju dla miłośników natury.">

    <title>Forest Group - Piękno natury w Krakowie</title>
    <!-- @include 'favicon.kit' -->
    <!-- @include 'styles.kit' -->
</head>

<body class="main-page">
    <!-- @include 'nav.kit' -->
    <header class="section header" id="home">
        <div class="wrapper header__text">
            <p class="header__description">Forest Group</p>
            <h1 class="header__title">Najpiękniejszy park w Twojej okolicy!</h1>
        </div>
    </header>


    <main class="main">
        <section class="section section-padding about-us" id="about-us">
            <div class="wrapper">
                <h2 class="section-heading">o nas</h2>
                <div class="about-us__box">
                    <img src="./dist/img/waters_640.jpg" alt="Dojrzewający krzew w kamieniu na rzece" class="img">
                    <div>
                        <h3 class="about-us__title">Niezapomniane przygody</h3>
                        <p class="about-us__text">Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do
                            eiusmod
                            tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim
                            veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea
                            commodo consequat. Duis aute irure dolor in reprehenderit in voluptate
                            velit esse cillum dolore eu fugiat nulla pariatur. Excepteur sint occaecat
                            cupidatat non proident, sunt in culpa qui officia deserunt mollit anim id est
                            laborum.</p>
                    </div>
                </div>
            </div>
        </section>
        <section class="hero-img">
            <p class="hero-img__title">Przygoda dla całej rodziny</p>
        </section>
        <section class="section section-padding  offers" id="offers">
            <!-- NOTE: Sprawdzić co oznacza onclick=void(0) w projekcie Tropical paradise -->
            <div class="wrapper">
                <h2 class="section-heading">Oferta</h2>
                <p class="offers-description">Wybierz jedną z naszych wspaniałych ofert!</p>
                <div class="offers__boxes">
                    <div class="offers__box">
                        <h3 class="offers__box-title">Demo</h3>
                        <p class="offers__box-price">$0</p>
                        <ul class="offers__list">
                            <li class="offers__list-item active-item">opcja w pakiecie</li>
                            <li class="offers__list-item active-item">opcja w pakiecie</li>
                            <li class="offers__list-item disabled-item">opcja poza pakietem</li>
                            <li class="offers__list-item disabled-item">opcja poza pakietem</li>
                            <li class="offers__list-item disabled-item">opcja poza pakietem</li>
                        </ul>
                        <button class="offers__btn">Wybierz</button>
                    </div>
                    <div class="offers__box">
                        <h3 class="offers__box-title">Standard</h3>
                        <p class="offers__box-price">$99</p>
                        <ul class="offers__list">
                            <li class="offers__list-item active-item">opcja w pakiecie</li>
                            <li class="offers__list-item active-item">opcja w pakiecie</li>
                            <li class="offers__list-item active-item">opcja w pakiecie</li>
                            <li class="offers__list-item disabled-item">opcja poza pakietem</li>
                            <li class="offers__list-item disabled-item">opcja poza pakietem</li>
                        </ul>
                        <button class="offers__btn offers__btn--special">Wybierz</button>
                    </div>
                    <div class="offers__box">
                        <h3 class="offers__box-title">Premium</h3>
                        <p class="offers__box-price">$299</p>
                        <ul class="offers__list">
                            <li class="offers__list-item active-item">opcja w pakiecie</li>
                            <li class="offers__list-item active-item">opcja w pakiecie</li>
                            <li class="offers__list-item active-item">opcja w pakiecie</li>
                            <li class="offers__list-item active-item">opcja w pakiecie</li>
                            <li class="offers__list-item active-item">opcja w pakiecie</li>
                        </ul>
                        <button class="offers__btn">Wybierz</button>
                    </div>
                </div>

                <span class="offers-description">Poznaj <a class="offers-description-link" href="offers.html">szczegóły
                        ofert >></a></span>
            </div>
        </section>
    </main>
    <!-- @include 'footer.kit' -->
    <!-- @include 'script.kit' -->
</body>

</html>